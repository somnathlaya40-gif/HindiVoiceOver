<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 Hindi Voice Over Generator"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:gravity="center"
            android:layout_marginBottom="10dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="12 Professional Male Voices"
            android:textSize="14sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="30dp" />

        <!-- Script Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📝 Enter Your Script"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="10dp" />

        <EditText
            android:id="@+id/scriptInput"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:hint="Paste your movie script here..."
            android:background="#FFFFFF"
            android:padding="15dp"
            android:textSize="14sp"
            android:gravity="top|start"
            android:layout_marginBottom="25dp" />

        <!-- Voice Selection -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎤 Select Professional Voice"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="15dp" />

        <RadioGroup
            android:id="@+id/voiceSelection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp">

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Deep Narrator - Documentary style"
                android:textSize="13sp"
                android:padding="10dp"
                android:checked="true" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="2. Serious Anchor - News channel"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="3. Dramatic Voice - Movie trailer"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="4. Smooth Narrator - Story telling"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="5. Powerful Bass - Epic movies"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="6. Clear & Crisp - Educational"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="7. Emotional - Drama/Romance"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="8. Energy Packed - Action scenes"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="9. Gentle Storyteller - Soft scenes"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="10. Royal/Majestic - Historical"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="11. Street Smart - Comedy/Casual"
                android:textSize="13sp"
                android:padding="10dp" />

            <RadioButton
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="12. Documentary Pro - Professional"
                android:textSize="13sp"
                android:padding="10dp" />
        </RadioGroup>

        <!-- Speed Control -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚡ Speed Control"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Slow"
                android:textSize="12sp"
                android:layout_marginRight="10dp" />

            <SeekBar
                android:id="@+id/speedControl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fast"
                android:textSize="12sp"
                android:layout_marginLeft="10dp" />
        </LinearLayout>

        <!-- Pitch Control -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎵 Pitch Adjustment"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Low"
                android:textSize="12sp"
                android:layout_marginRight="10dp" />

            <SeekBar
                android:id="@+id/pitchControl"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:max="100"
                android:progress="50" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="High"
                android:textSize="12sp"
                android:layout_marginLeft="10dp" />
        </LinearLayout>

        <!-- Generate Button -->
        <Button
            android:id="@+id/generateButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="🎤 GENERATE VOICE"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#4CAF50"
            android:layout_marginBottom="15dp" />

        <!-- Download Button -->
        <Button
            android:id="@+id/downloadButton"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="💾 DOWNLOAD MP3"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="#2196F3"
            android:layout_marginBottom="30dp" />

    </LinearLayout>

</ScrollView>
